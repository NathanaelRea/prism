#!/usr/bin/env bash
set -euo pipefail

tool="$(basename "$0")"
root="${PRISM_DEMO_ROOT:?PRISM_DEMO_ROOT is required}"
log_dir="$root/logs"
mkdir -p "$log_dir"
{
  printf 'tool=%s\n' "$tool"
  printf 'cwd=%s\n' "$(pwd)"
  printf 'argv='
  printf '%q ' "$@"
  printf '\n\n'
} >>"$log_dir/$tool.log"

case "${1:-}" in
  +%H:%M:%S)
    printf '12:00:00\n'
    ;;
  *)
    exec /usr/bin/date "$@"
    ;;
esac
