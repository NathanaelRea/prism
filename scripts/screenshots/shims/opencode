#!/usr/bin/env bash
set -euo pipefail

tool="$(basename "$0")"
root="${PRISM_DEMO_ROOT:?PRISM_DEMO_ROOT is required}"
log_dir="$root/logs"
state_dir="$root/state/opencode"
mkdir -p "$log_dir" "$state_dir"
{
  printf 'tool=%s\n' "$tool"
  printf 'cwd=%s\n' "$(pwd)"
  printf 'argv='
  printf '%q ' "$@"
  printf '\n'
  printf 'HOME=%s\n' "${HOME:-}"
  printf 'XDG_CONFIG_HOME=%s\n' "${XDG_CONFIG_HOME:-}"
  printf 'OPENCODE_CONFIG_DIR=%s\n' "${OPENCODE_CONFIG_DIR:-}"
  printf 'PRISM_DEMO_ROOT=%s\n\n' "$root"
} >>"$log_dir/$tool.log"

unsupported() {
  {
    printf 'UNSUPPORTED argv='
    printf '%q ' "$@"
    printf '\n'
  } >>"$log_dir/$tool.log"
  printf 'opencode shim: unsupported command:' >&2
  printf ' %q' "$@" >&2
  printf '\n' >&2
  exit 64
}

if [[ "${1:-}" == "--version" ]]; then
  printf 'opencode 0.0.0-prism-demo\n'
  exit 0
fi

case "${1:-}" in
  "")
    printf '\033[2J\033[H'
    printf 'OpenCode Demo Session\n'
    printf 'Mode: interactive fallback\n\n'
    printf 'assistant: I am ready for a follow-up prompt in this worktree.\n'
    printf 'tool: bash idle\n'
    printf 'todo:\n  [x] load worktree context\n  [ ] wait for prompt\n\n'
    printf '> '
    while true; do sleep 60; done
    ;;
  serve)
    shift
    hostname="127.0.0.1"
    port=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --hostname)
          [[ $# -ge 2 ]] || unsupported serve "$@"
          hostname="$2"
          shift 2
          ;;
        --port)
          [[ $# -ge 2 ]] || unsupported serve "$@"
          port="$2"
          shift 2
          ;;
        *)
          unsupported serve "$@"
          ;;
      esac
    done
    [[ -n "$port" ]] || unsupported serve --missing-port
    printf 'hostname=%s\nport=%s\npid=%s\n' "$hostname" "$port" "$$" >"$state_dir/server-$port.ready"
    exec python3 - "$root" "$hostname" "$port" <<'PY'
import json, os, sys
from http.server import BaseHTTPRequestHandler, HTTPServer
from urllib.parse import unquote, urlparse

root, host, port = sys.argv[1], sys.argv[2], int(sys.argv[3])
state_dir = os.path.join(root, "state", "opencode")
sessions_path = os.path.join(state_dir, f"sessions-{port}.json")

def read_sessions():
    try:
        with open(sessions_path, encoding="utf-8") as handle:
            return json.load(handle)
    except FileNotFoundError:
        return []

def write_sessions(sessions):
    with open(sessions_path, "w", encoding="utf-8") as handle:
        json.dump(sessions, handle, indent=2)
        handle.write("\n")

def session_payload(session):
    return {"id": session["id"], "directory": session.get("directory"), "title": session.get("title"), "timeUpdated": session.get("timeUpdated")}

def session_status(session):
    directory = session.get("directory") or ""
    if directory.endswith("/agent-session") or directory.endswith("/review-comments"):
        return "busy"
    if directory.endswith("/ci-green"):
        return "done"
    if directory.endswith("/wishlist") or directory.endswith("/catalog-index"):
        return "needs input"
    return "idle"

class Handler(BaseHTTPRequestHandler):
    server_version = "PrismDemoOpenCode/0"

    def log_message(self, *_args):
        return

    def send_json(self, status, value):
        body = json.dumps(value).encode()
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self):
        path = urlparse(self.path).path
        sessions = read_sessions()
        if path == "/global/health":
            self.send_json(200, {"ok": True})
        elif path == "/session":
            self.send_json(200, {"data": [session_payload(item) for item in sessions]})
        elif path.startswith("/session/") and path.endswith("/message"):
            self.send_json(200, {"data": [
                {"role": "user", "text": "Review the comments on PR 17 and fix if applicable"},
                {"role": "assistant", "text": "I mapped the storefront workflow and am applying the demo-safe fix."},
                {"type": "tool", "name": "task running"},
            ]})
        elif path.startswith("/session/") and path.endswith("/todo"):
            self.send_json(200, {"todos": [
                {"content": "Inspect checkout flow", "status": "done"},
                {"content": "Patch recommendation copy", "status": "in_progress"},
                {"content": "Run focused smoke check", "status": "pending"},
            ]})
        elif path == "/session/status":
            self.send_json(200, {item["id"]: session_status(item) for item in sessions})
        elif path == "/event":
            session = sessions[0] if sessions else {"id": "ses_demo", "directory": ""}
            status = session_status(session)
            events = [
                {"type": "session.status", "properties": {"sessionID": session["id"], "status": status, "title": "Demo storefront"}},
                {"type": "message.part.updated", "properties": {"sessionID": session["id"], "role": "assistant", "text": "Review the comments on PR 17 and fix if applicable"}},
            ]
            if status == "busy":
                events.append({"type": "tool.updated", "properties": {"sessionID": session["id"], "name": "task running"}})
            body = "".join(f"data: {json.dumps(event)}\n\n" for event in events).encode()
            self.send_response(200)
            self.send_header("Content-Type", "text/event-stream")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
        elif path.startswith("/session/"):
            session_id = unquote(path.rsplit("/", 1)[-1])
            session = next((item for item in sessions if item["id"] == session_id), None)
            self.send_json(200 if session else 404, session_payload(session) if session else {"error": "not found"})
        else:
            self.send_json(404, {"error": f"unsupported path {path}"})

    def do_POST(self):
        path = urlparse(self.path).path
        length = int(self.headers.get("Content-Length") or "0")
        raw = self.rfile.read(length).decode() if length else "{}"
        try:
            body = json.loads(raw or "{}")
        except json.JSONDecodeError:
            body = {}
        sessions = read_sessions()
        if path == "/session":
            directory = body.get("directory") or os.getcwd()
            session_id = f"ses_demo_{len(sessions) + 1}"
            session = {"id": session_id, "directory": directory, "title": "Demo storefront", "timeUpdated": "2026-01-15T12:00:00Z"}
            sessions.append(session)
            write_sessions(sessions)
            self.send_json(201, session)
        elif path in ("/tui/append-prompt", "/tui/submit-prompt") or path.endswith("/abort"):
            self.send_json(200, {"ok": True})
        else:
            self.send_json(404, {"error": f"unsupported path {path}"})

HTTPServer((host, port), Handler).serve_forever()
PY
    ;;
  attach)
    url="${2:-}"
    [[ -n "$url" ]] || unsupported attach
    printf '\033[2J\033[H'
    printf 'OpenCode Demo Session\n'
    printf 'Server: %s\n\n' "$url"
    printf 'assistant: I found the review comment and failing CI fixture.\n'
    printf 'tool: bash running `npm test -- --run checkout`\n'
    printf 'todo:\n  [x] inspect review thread\n  [~] patch checkout guard\n  [ ] rerun smoke check\n\n'
    printf '> '
    while true; do sleep 60; done
    ;;
  run)
    shift
    format=""
    title="Demo plan phase"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --attach)
          [[ $# -ge 2 ]] || unsupported run "$@"
          shift 2
          ;;
        --format)
          [[ $# -ge 2 ]] || unsupported run "$@"
          format="$2"
          shift 2
          ;;
        --variant)
          [[ $# -ge 2 ]] || unsupported run "$@"
          shift 2
          ;;
        --dir)
          [[ $# -ge 2 ]] || unsupported run "$@"
          shift 2
          ;;
        --title)
          [[ $# -ge 2 ]] || unsupported run "$@"
          title="$2"
          shift 2
          ;;
        --*)
          unsupported run "$@"
          ;;
        *)
          prompt="$1"
          shift
          ;;
      esac
    done
    [[ "$format" == "json" ]] || unsupported run --format "$format"
    session="ses_plan_demo"
    printf '{"type":"session.status","sessionID":"%s","title":"%s","status":"running"}\n' "$session" "$title"
    sleep 0.15
    printf '{"type":"todo.updated","sessionID":"%s","todos":[{"content":"Read phase instructions","status":"done"},{"content":"Apply deterministic fixture changes","status":"in_progress"},{"content":"Run smoke checks","status":"pending"}]}\n' "$session"
    sleep 0.15
    printf '{"type":"tool.updated","sessionID":"%s","id":"tool_1","name":"bash","status":"running","command":"git status --short"}\n' "$session"
    sleep 0.15
    printf '{"type":"message.part.updated","sessionID":"%s","role":"assistant","text":"Implemented the requested phase with deterministic sandbox fixtures."}\n' "$session"
    sleep 0.15
    printf '{"type":"tool.updated","sessionID":"%s","id":"tool_1","name":"bash","status":"completed","output":"smoke checks passed"}\n' "$session"
    sleep 0.15
    printf '{"type":"session.idle","sessionID":"%s","status":"idle"}\n' "$session"
    ;;
  *)
    unsupported "$@"
    ;;
esac
