#!/usr/bin/env bash
set -euo pipefail

tool="$(basename "$0")"
root="${PRISM_DEMO_ROOT:?PRISM_DEMO_ROOT is required}"
log_dir="$root/logs"
mkdir -p "$log_dir" "$root/state"
{
  printf 'tool=%s\n' "$tool"
  printf 'cwd=%s\n' "$(pwd)"
  printf 'argv='
  printf '%q ' "$@"
  printf '\n\n'
} >>"$log_dir/$tool.log"

if [[ "${1:-}" == "--version" ]]; then
  printf 'wl-copy prism-demo\n'
  exit 0
fi

cat >"$root/state/clipboard.txt"
