#!/usr/bin/env bash
set -euo pipefail

tool="$(basename "$0")"
root="${PRISM_DEMO_ROOT:-/tmp}"
log_dir="$root/logs"
mkdir -p "$log_dir"
{
  printf 'tool=%s\n' "$tool"
  printf 'cwd=%s\n' "$(pwd)"
  printf 'argv='
  printf '%q ' "$@"
  printf '\nUNSUPPORTED missing clipboard fallback\n\n'
} >>"$log_dir/$tool.log"
printf '%s is intentionally unavailable in the Prism screenshot sandbox\n' "$tool" >&2
exit 127
