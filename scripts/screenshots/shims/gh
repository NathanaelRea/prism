#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" == "--version" ]]; then
  printf 'gh version 2.99.0-prism-screenshot\n'
  exit 0
fi
if [[ "${1:-}" == "auth" && "${2:-}" == "status" ]]; then
  printf 'github.com\n  Logged in to github.com account prism-demo\n'
  exit 0
fi
if [[ "${1:-}" == "api" && "${2:-}" == "graphql" ]]; then
  if [[ "$*" == *"pullRequests"* ]]; then
    # Keep refresh in flight while VHS captures the pre-seeded PR cache.
    sleep 10
  fi
  printf '{"data":{"repository":{"defaultBranchRef":{"name":"main"},"branchProtectionRules":{"nodes":[]},"pullRequests":{"nodes":[]}}}}\n'
  exit 0
fi
printf 'gh screenshot shim: unsupported command\n' >&2
exit 64
